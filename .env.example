# ─── Backend ────────────────────────────────────────────────────
PORT=5055
NODE_ENV=development

# MongoDB connection string (leave empty to use in-memory seed data)
# Use a dedicated database name, e.g. /tuti, before the query string.
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/tuti?retryWrites=true&w=majority&appName=Cluster0

# JWT secrets — use strong random strings in production
JWT_SECRET=change-me-in-production-minimum-32-chars
JWT_REFRESH_SECRET=change-refresh-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origins for CORS. Include every portal app that calls the API.
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ─── Frontend ────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5055/api

# Portal URLs — used by the web app to link to separate portal apps.
# In production, set these to your deployed subdomain or path.
# In development the web app falls back to localhost port numbers.
VITE_SELLER_URL=http://localhost:5174
VITE_DRIVER_URL=http://localhost:5176
VITE_SR_URL=http://localhost:5177
VITE_ADMIN_URL=http://localhost:5175
