# apps/web/.env.example
# Document of all required environment variables.
#
# PRODUCTION NOTE: All VITE_* portal variables must be configured in your
# production hosting environment (CI secrets, hosting env vars, etc.).
# If a portal variable is missing in production, the corresponding link is
# hidden from the public navigation. Localhost URLs are never shown in
# production — they are only used in development via .env.development.local.
#
# For local development:
#   Copy this file to .env.development.local and fill in localhost ports.
#   .env.development.local is loaded by Vite in dev mode only (not during build).
#   Never commit .env.local or .env.*.local files.

VITE_API_URL=
VITE_SELLER_URL=
VITE_DRIVER_URL=
VITE_SR_URL=
VITE_ADMIN_URL=
